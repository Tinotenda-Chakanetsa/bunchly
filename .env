# =====================================================================
# Bunchly — local development environment
# Copy this file to `.env` (same directory as docker-compose.yml).
# =====================================================================

# --- Core Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,bunchly_backend
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3001,http://localhost:5173

# --- Database & Redis (matches docker-compose service names) ---
POSTGRES_USER=bunchly
POSTGRES_PASSWORD=bunchly
POSTGRES_DB=bunchly
DATABASE_URL=postgres://bunchly:bunchly@bunchly_postgres:5432/bunchly
REDIS_URL=redis://bunchly_redis:6379/0
CELERY_BROKER_URL=redis://bunchly_redis:6379/1
CELERY_RESULT_BACKEND=redis://bunchly_redis:6379/2

# --- Exposed host ports (override if any are taken) ---
# All four ports are chosen to sit OUTSIDE Windows Hyper-V's typical
# ephemeral-port reservation bands (which shift on reboot). Symptoms
# when a chosen port collides: docker compose up fails with
#   "bind: An attempt was made to access a socket in a way forbidden
#    by its access permissions"
# Check current reservations with:
#   netsh int ipv4 show excludedportrange protocol=tcp
POSTGRES_PORT=5433
REDIS_PORT=6800
BACKEND_PORT=8200
FRONTEND_PORT=8088

# --- Email: Resend preferred, SMTP fallback ---
# EMAIL_PROVIDER must be set to "resend" for the Resend API path to be
# taken — otherwise the dispatcher falls back to SMTP.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_W5WZk7q4_MvML6ZaarJaBwYkGsfimUjQK
# IMPORTANT: Resend rejects sends from a `from` address whose domain you
# haven't verified. On a fresh Resend account the only verified address
# is the one tied to onboarding@resend.dev. Until you verify your own
# domain at resend.com/domains, leave DEFAULT_FROM_EMAIL as the Resend
# sandbox sender and use DEFAULT_REPLY_TO_EMAIL to route replies to you.
DEFAULT_FROM_EMAIL=Bunchly <onboarding@resend.dev>
DEFAULT_REPLY_TO_EMAIL=tinotendachakanetsa2003@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- File storage ---
FILE_STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# --- JWT & throttling ---
JWT_SIGNING_KEY=
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# --- Frontend build-time ---
# Same-origin in production behind the bundled nginx; override when the
# frontend is served from a different host than the API.
VITE_API_BASE_URL=/api/v1
