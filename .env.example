# =====================================================================
# Bunchly — local development environment
# Copy this file to `.env` (same directory as docker-compose.yml).
# =====================================================================

# --- Core Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,bunchly_backend
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# --- Database & Redis (matches docker-compose service names) ---
POSTGRES_USER=bunchly
POSTGRES_PASSWORD=bunchly
POSTGRES_DB=bunchly
DATABASE_URL=postgres://bunchly:bunchly@bunchly_postgres:5432/bunchly
REDIS_URL=redis://bunchly_redis:6379/0
CELERY_BROKER_URL=redis://bunchly_redis:6379/1
CELERY_RESULT_BACKEND=redis://bunchly_redis:6379/2

# --- Exposed host ports (override if 5433/6380/8001/3001 are taken) ---
POSTGRES_PORT=5433
REDIS_PORT=6380
BACKEND_PORT=8001
FRONTEND_PORT=3001

# --- Email: Resend preferred, SMTP fallback ---
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=Bunchly <no-reply@bunchly.local>
DEFAULT_REPLY_TO_EMAIL=hr@bunchly.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- File storage ---
FILE_STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# --- JWT & throttling ---
JWT_SIGNING_KEY=
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# --- Frontend build-time ---
# Same-origin in production behind the bundled nginx; override when the
# frontend is served from a different host than the API.
VITE_API_BASE_URL=/api/v1
