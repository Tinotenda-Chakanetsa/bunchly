# =====================================================================
# Bunchly — Tailscale VM deployment environment.
# Copy to .env.vm on the VM, fill in the TODO markers, then bring the
# stack up with:
#
#   docker compose -f docker-compose.yml -f docker-compose.vm.yml \
#     --env-file .env.vm up -d postgres redis backend celery_worker celery_beat
#
# Once Vercel gives you a frontend URL, update CORS_ALLOWED_ORIGINS and
# restart the backend (docker compose ... restart backend).
# =====================================================================

# --- Core Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
# TODO: generate with `python -c "import secrets; print(secrets.token_urlsafe(64))"`
SECRET_KEY=REPLACE_ME_64_RANDOM_CHARS
# TODO: generate a second value with the same command for JWT signing.
JWT_SECRET=REPLACE_ME_64_RANDOM_CHARS
DEBUG=false
# Funnel forwards the public hostname as the Host header. Add the VM's
# Linux hostname too so localhost-style health probes still work.
ALLOWED_HOSTS=user-hvm-domu.taile2f0da.ts.net,localhost,127.0.0.1,bunchly_backend
# TODO: once Vercel deploys, replace the placeholder with the real domain.
CORS_ALLOWED_ORIGINS=https://REPLACE_ME.vercel.app
# Django admin (rarely used here, but harmless to whitelist the funnel host).
CSRF_TRUSTED_ORIGINS=https://user-hvm-domu.taile2f0da.ts.net

# --- Database & Redis (containers on the bunchly_net bridge) ---
POSTGRES_USER=bunchly
POSTGRES_PASSWORD=bunchly
POSTGRES_DB=bunchly
DATABASE_URL=postgres://bunchly:bunchly@bunchly_postgres:5432/bunchly
REDIS_URL=redis://bunchly_redis:6379/0
CELERY_BROKER_URL=redis://bunchly_redis:6379/1
CELERY_RESULT_BACKEND=redis://bunchly_redis:6379/2

# --- Host port for the backend (Funnel proxies this) ---
# Must be unique on the VM. Confirmed free: 8000 -> /, 3015 -> /cms/.
BACKEND_PORT=8200

# --- Email (Resend in production) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_W5WZk7q4_MvML6ZaarJaBwYkGsfimUjQK
DEFAULT_FROM_EMAIL=Bunchly <onboarding@resend.dev>
DEFAULT_REPLY_TO_EMAIL=tinotendachakanetsa2003@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- File storage (S3 recommended later; local is fine for a temp deploy) ---
FILE_STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# --- Throttling / lockout ---
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# --- Tailscale-aware HTTPS ---
# Tailscale Funnel terminates TLS and forwards over HTTP with
# X-Forwarded-Proto: https. prod.py already trusts that header via
# SECURE_PROXY_SSL_HEADER, so Django will not redirect-loop.
SECURE_SSL_REDIRECT=true

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
